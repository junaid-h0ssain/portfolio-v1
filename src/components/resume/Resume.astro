---
import type { ResumeData } from '../../types/resume';

interface Props {
  data: ResumeData;
}

const { data } = Astro.props;
---

<div class="min-h-screen bg-white text-gray-900 print:bg-white">
  <!-- Header Section -->
  <header class="border-b border-gray-200 pb-6 mb-6 print:pb-4 print:mb-4">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-2 print:text-3xl">{data.personalInfo.name}</h1>
      <p class="text-xl text-gray-600 mb-4 print:text-lg">{data.personalInfo.title}</p>
      
      <!-- Contact Info -->
      <div class="flex flex-wrap gap-4 text-sm text-gray-600 print:text-xs print:gap-2">
        {data.personalInfo.email && (
          <a href={`mailto:${data.personalInfo.email}`} class="hover:text-blue-600 print:no-underline">
            {data.personalInfo.email}
          </a>
        )}
        {data.personalInfo.phone && (
          <span>{data.personalInfo.phone}</span>
        )}
        {data.personalInfo.location && (
          <span>{data.personalInfo.location}</span>
        )}
        {data.personalInfo.website && (
          <a href={data.personalInfo.website} class="hover:text-blue-600 print:no-underline">
            {data.personalInfo.website}
          </a>
        )}
        {data.personalInfo.github && (
          <a href={data.personalInfo.github} class="hover:text-blue-600 print:no-underline">
            GitHub
          </a>
        )}
        {data.personalInfo.linkedin && (
          <a href={data.personalInfo.linkedin} class="hover:text-blue-600 print:no-underline">
            LinkedIn
          </a>
        )}
      </div>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Experience Section -->
    {data.experience && data.experience.length > 0 && (
      <section class="mb-8 print:mb-4">
        <h2 class="text-2xl font-bold mb-4 border-b border-gray-300 pb-2 print:text-xl print:mb-2 print:pb-1">
          Experience
        </h2>
        <div class="space-y-6 print:space-y-3">
          {data.experience.map((job) => (
            <div class="print:page-break-inside-avoid">
              <div class="flex justify-between items-start mb-1">
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 print:text-base">{job.position}</h3>
                  <p class="text-gray-600 print:text-sm">{job.company}</p>
                </div>
                <span class="text-sm text-gray-500 whitespace-nowrap print:text-xs">
                  {job.startDate} – {job.endDate}
                </span>
              </div>
              <p class="text-gray-700 mb-2 print:text-sm">{job.description}</p>
              {job.achievements && job.achievements.length > 0 && (
                <ul class="list-disc list-inside text-gray-700 mb-2 print:text-sm print:mb-1">
                  {job.achievements.map((achievement) => (
                    <li class="text-sm print:text-xs">{achievement}</li>
                  ))}
                </ul>
              )}
              {job.technologies && job.technologies.length > 0 && (
                <p class="text-sm text-gray-600 print:text-xs">
                  <span class="font-semibold">Technologies:</span> {job.technologies.join(', ')}
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Education Section -->
    {data.education && data.education.length > 0 && (
      <section class="mb-8 print:mb-4">
        <h2 class="text-2xl font-bold mb-4 border-b border-gray-300 pb-2 print:text-xl print:mb-2 print:pb-1">
          Education
        </h2>
        <div class="space-y-4 print:space-y-2">
          {data.education.map((edu) => (
            <div class="print:page-break-inside-avoid">
              <div class="flex justify-between items-start mb-1">
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 print:text-base">
                    {edu.degree} in {edu.field}
                  </h3>
                  <p class="text-gray-600 print:text-sm">{edu.institution}</p>
                </div>
                <span class="text-sm text-gray-500 whitespace-nowrap print:text-xs">
                  {edu.startDate} – {edu.endDate}
                </span>
              </div>
              {edu.gpa && (
                <p class="text-sm text-gray-600 print:text-xs">GPA: {edu.gpa}</p>
              )}
              {edu.achievements && edu.achievements.length > 0 && (
                <ul class="list-disc list-inside text-gray-700 text-sm print:text-xs">
                  {edu.achievements.map((achievement) => (
                    <li>{achievement}</li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Skills Section -->
    {data.skills && data.skills.length > 0 && (
      <section class="mb-8 print:mb-4">
        <h2 class="text-2xl font-bold mb-4 border-b border-gray-300 pb-2 print:text-xl print:mb-2 print:pb-1">
          Skills
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 print:grid-cols-2 print:gap-3">
          {data.skills.map((skillGroup) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2 print:text-sm print:mb-1">
                {skillGroup.category}
              </h3>
              <p class="text-gray-700 text-sm print:text-xs">
                {skillGroup.skills.join(', ')}
              </p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Certifications Section -->
    {data.certifications && data.certifications.length > 0 && (
      <section class="mb-8 print:mb-4">
        <h2 class="text-2xl font-bold mb-4 border-b border-gray-300 pb-2 print:text-xl print:mb-2 print:pb-1">
          Certifications
        </h2>
        <div class="space-y-3 print:space-y-2">
          {data.certifications.map((cert) => (
            <div class="print:page-break-inside-avoid">
              <div class="flex justify-between items-start">
                <div>
                  <h3 class="font-semibold text-gray-900 print:text-sm">{cert.name}</h3>
                  <p class="text-gray-600 text-sm print:text-xs">{cert.issuer}</p>
                </div>
                <span class="text-sm text-gray-500 whitespace-nowrap print:text-xs">{cert.date}</span>
              </div>
              {cert.url && (
                <a href={cert.url} class="text-blue-600 hover:underline text-sm print:text-xs print:no-underline">
                  View Certificate
                </a>
              )}
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</div>

<style>
  @media print {
    :global(body) {
      margin: 0;
      padding: 0;
    }
    
    @page {
      margin: 0.5in;
      size: letter;
    }
  }
</style>
