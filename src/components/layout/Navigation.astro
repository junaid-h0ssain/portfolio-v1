---
import MobileMenu from './MobileMenu';
import { withBase } from '../../lib/utils';

interface Props {
  currentPath: string;
  isLight?: boolean;
}

const { currentPath, isLight = false } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
};

const homeHref = withBase('/');
---

<header class={`sticky top-0 z-50 w-full border-b backdrop-blur-sm ${
  isLight
    ? 'border-gray-300/80 bg-white/92'
    : 'border-secondary-600/70 bg-secondary-950/85'
}`}>
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo/Brand -->
      <div class="shrink-0">
        <a href={homeHref} class={`text-xl font-bold ${isLight ? 'text-gray-900' : 'text-primary-200'}`}>
          Junaid Hossain
        </a>
      </div>
      
      <!-- Desktop Navigation -->
      <div class="hidden md:block">
        <div class="flex items-center space-x-8">
          {navLinks.map((link) => (
            <a
              href={withBase(link.href)}
              class={`text-sm font-medium transition-colors ${
                isLight ? 'hover:text-gray-900' : 'hover:text-primary-300'
              } ${
                isActive(link.href)
                  ? isLight ? 'text-gray-900' : 'text-primary-300'
                  : isLight ? 'text-gray-600' : 'text-primary-100/80'
              }`}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
      
      <!-- Mobile Menu Toggle -->
      <div class="md:hidden">
        <MobileMenu links={navLinks} currentPath={currentPath} isLight={isLight} client:visible />
      </div>
    </div>
  </nav>
</header>
