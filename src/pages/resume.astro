---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ResumeSection from '../components/resume/Resume.astro';
import resumeData from '../data/resume.json';
import type { ResumeData } from '../types/resume';

const data: ResumeData = resumeData;
---

<BaseLayout
  title="Resume - Junaid Hossain"
  description="Professional resume of Junaid Hossain, Full Stack Developer"
  image="/og-resume.png"
  theme="light"
>
  <head>
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Resume - Junaid Hossain" />
    <meta property="og:description" content="Professional resume of Junaid Hossain, Full Stack Developer" />
    <meta name="print-color-adjust" content="exact" />
    <meta name="webkit-print-color-adjust" content="exact" />
    <style>
      @media print {
        @page {
          margin: 0.5in;
          size: letter;
        }
        
        body {
          margin: 0;
          padding: 0;
          background: white;
        }
      }
    </style>
  </head>
  
  <main class="min-h-screen bg-white py-8 print:bg-white print:py-0">
    <div class="print:max-w-full">
      <ResumeSection data={data} />
    </div>
  </main>
</BaseLayout>
