---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../components/layout/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await project.render();
const { 
  title, 
  description, 
  technologies, 
  repositoryUrl, 
  liveUrl, 
  thumbnail,
  featured,
  startDate,
  endDate 
} = project.data;

// Format dates
const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short'
  });
};

const formattedStartDate = formatDate(startDate);
const formattedEndDate = endDate ? formatDate(endDate) : 'Present';
const projectDuration = `${formattedStartDate} - ${formattedEndDate}`;
---

<BaseLayout title={title} description={description} image={thumbnail}>
  <!-- Hero Section -->
  <div class="project-hero">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="project-hero-inner">
        <!-- Featured badge -->
        {featured && (
          <div class="mb-4">
            <span class="featured-badge">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              Featured Project
            </span>
          </div>
        )}

        <!-- Title -->
        <h1 class="project-title">{title}</h1>

        <!-- Description -->
        <p class="project-description">{description}</p>

        <!-- Meta row -->
        <div class="project-meta">
          <div class="meta-item">
            <svg xmlns="http://www.w3.org/2000/svg" class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span>{projectDuration}</span>
          </div>

          <div class="meta-item">
            <svg xmlns="http://www.w3.org/2000/svg" class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
            <span>{technologies.length} Technologies</span>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="action-buttons">
          {liveUrl && (
            <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              View Live Demo
            </a>
          )}
          <a href={repositoryUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
            View Repository
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl py-10">
    <div class="project-layout">
      <!-- Main content area -->
      <article class="project-content">
        <!-- Project thumbnail -->
        <div class="project-thumbnail">
          <Image 
            src={thumbnail} 
            alt={`${title} screenshot`}
            width={1200}
            height={675}
            class="rounded-xl shadow-lg"
            loading="eager"
          />
        </div>

        <!-- Technologies used -->
        <div class="tech-section">
          <h2 class="section-heading">Technologies Used</h2>
          <div class="tech-grid">
            {technologies.map((tech) => (
              <span class="tech-badge">{tech}</span>
            ))}
          </div>
        </div>

        <!-- MDX Content -->
        <div class="prose prose-lg dark:prose-invert max-w-none
                    prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white
                    prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
                    prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                    prose-p:text-gray-700 dark:prose-p:text-gray-300 prose-p:leading-relaxed
                    prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline
                    prose-code:text-pink-600 dark:prose-code:text-pink-400 prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
                    prose-pre:relative prose-pre:bg-gray-900 dark:prose-pre:bg-gray-950 prose-pre:text-gray-100 prose-pre:rounded-xl prose-pre:shadow-lg
                    prose-strong:text-gray-900 dark:prose-strong:text-white
                    prose-ul:text-gray-700 dark:prose-ul:text-gray-300
                    prose-ol:text-gray-700 dark:prose-ol:text-gray-300
                    prose-li:text-gray-700 dark:prose-li:text-gray-300
                    prose-blockquote:border-blue-400 prose-blockquote:text-gray-600 dark:prose-blockquote:text-gray-400
                    prose-img:rounded-lg prose-img:shadow-md">
          <Content />
        </div>

        <!-- Footer -->
        <footer class="project-footer">
          <div class="project-footer-inner">
            <a href="/projects" class="back-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
              </svg>
              Back to Projects
            </a>

            <button id="share-btn" class="share-btn" title="Copy link to clipboard">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
              <span id="share-label">Copy link</span>
            </button>
          </div>
        </footer>
      </article>

      <!-- Sidebar with project info -->
      <aside class="project-sidebar" aria-label="Project information">
        <div class="sidebar-inner">
          <h3 class="sidebar-heading">Project Details</h3>
          
          <div class="sidebar-section">
            <h4 class="sidebar-label">Duration</h4>
            <p class="sidebar-value">{projectDuration}</p>
          </div>

          <div class="sidebar-section">
            <h4 class="sidebar-label">Status</h4>
            <p class="sidebar-value">{endDate ? 'Completed' : 'In Progress'}</p>
          </div>

          {featured && (
            <div class="sidebar-section">
              <h4 class="sidebar-label">Highlight</h4>
              <p class="sidebar-value">Featured Project</p>
            </div>
          )}

          <div class="sidebar-divider"></div>

          <div class="sidebar-links">
            {liveUrl && (
              <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="sidebar-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Live Demo
              </a>
            )}
            <a href={repositoryUrl} target="_blank" rel="noopener noreferrer" class="sidebar-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              Repository
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Hero ── */
  .project-hero {
    background: linear-gradient(135deg,
      rgb(239 246 255) 0%,
      rgb(219 234 254) 40%,
      rgb(224 231 255) 100%);
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid rgb(219 234 254);
    animation: fadeUp 0.5s ease both;
  }
  :global(.dark) .project-hero {
    background: linear-gradient(135deg,
      rgb(15 23 42) 0%,
      rgb(23 37 84) 40%,
      rgb(17 24 39) 100%);
    border-bottom-color: rgb(30 58 138 / 0.4);
  }
  .project-hero-inner {
    max-width: 780px;
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: linear-gradient(135deg, rgb(251 191 36), rgb(245 158 11));
    color: rgb(120 53 15);
    border-radius: 9999px;
    box-shadow: 0 2px 8px rgb(251 191 36 / 0.3);
  }
  :global(.dark) .featured-badge {
    background: linear-gradient(135deg, rgb(217 119 6), rgb(180 83 9));
    color: rgb(254 243 199);
  }

  .project-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: rgb(17 24 39);
    margin-bottom: 1rem;
  }
  :global(.dark) .project-title { color: white; }

  .project-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgb(55 65 81);
    margin-bottom: 1.5rem;
  }
  :global(.dark) .project-description { color: rgb(209 213 219); }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(75 85 99);
  }
  :global(.dark) .meta-item { color: rgb(156 163 175); }
  .meta-icon { width: 1.125rem; height: 1.125rem; flex-shrink: 0; }

  .action-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-primary {
    background: rgb(37 99 235);
    color: white;
    border: 1px solid rgb(29 78 216);
  }
  .btn-primary:hover {
    background: rgb(29 78 216);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgb(37 99 235 / 0.3);
  }
  .btn-secondary {
    background: white;
    color: rgb(55 65 81);
    border: 1px solid rgb(209 213 219);
  }
  .btn-secondary:hover {
    background: rgb(249 250 251);
    border-color: rgb(156 163 175);
  }
  :global(.dark) .btn-secondary {
    background: rgb(31 41 55);
    color: rgb(209 213 219);
    border-color: rgb(55 65 81);
  }
  :global(.dark) .btn-secondary:hover {
    background: rgb(55 65 81);
  }

  /* ── Layout ── */
  .project-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .project-layout {
      grid-template-columns: minmax(0, 1fr) 280px;
    }
  }

  .project-content {
    min-width: 0;
  }

  /* ── Thumbnail ── */
  .project-thumbnail {
    margin-bottom: 2.5rem;
  }

  /* ── Technologies ── */
  .tech-section {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgb(229 231 235);
  }
  :global(.dark) .tech-section { border-bottom-color: rgb(55 65 81); }

  .section-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: rgb(17 24 39);
    margin-bottom: 1rem;
  }
  :global(.dark) .section-heading { color: white; }

  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .tech-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    background: rgb(239 246 255);
    color: rgb(29 78 216);
    border: 1px solid rgb(191 219 254);
    border-radius: 0.5rem;
    transition: all 0.15s;
  }
  .tech-badge:hover {
    background: rgb(219 234 254);
    transform: translateY(-1px);
  }
  :global(.dark) .tech-badge {
    background: rgb(30 58 138 / 0.4);
    color: rgb(147 197 253);
    border-color: rgb(30 58 138);
  }
  :global(.dark) .tech-badge:hover {
    background: rgb(30 58 138 / 0.6);
  }

  /* ── Sidebar ── */
  .project-sidebar {
    display: none;
  }
  @media (min-width: 1024px) {
    .project-sidebar {
      display: block;
    }
    .sidebar-inner {
      position: sticky;
      top: 5.5rem;
      padding: 1.5rem;
      background: white;
      border: 1px solid rgb(229 231 235);
      border-radius: 0.75rem;
      box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
    }
    :global(.dark) .sidebar-inner {
      background: rgb(17 24 39);
      border-color: rgb(55 65 81);
    }
  }

  .sidebar-heading {
    font-size: 1rem;
    font-weight: 700;
    color: rgb(17 24 39);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgb(229 231 235);
  }
  :global(.dark) .sidebar-heading {
    color: white;
    border-bottom-color: rgb(55 65 81);
  }

  .sidebar-section {
    margin-bottom: 1.25rem;
  }
  .sidebar-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgb(107 114 128);
    margin-bottom: 0.375rem;
  }
  :global(.dark) .sidebar-label { color: rgb(156 163 175); }

  .sidebar-value {
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgb(17 24 39);
  }
  :global(.dark) .sidebar-value { color: rgb(229 231 235); }

  .sidebar-divider {
    height: 1px;
    background: rgb(229 231 235);
    margin: 1.5rem 0;
  }
  :global(.dark) .sidebar-divider { background: rgb(55 65 81); }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(37 99 235);
    background: rgb(239 246 255);
    border: 1px solid rgb(191 219 254);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.15s;
  }
  .sidebar-link:hover {
    background: rgb(219 234 254);
    transform: translateX(2px);
  }
  :global(.dark) .sidebar-link {
    color: rgb(96 165 250);
    background: rgb(23 37 84 / 0.4);
    border-color: rgb(30 58 138);
  }
  :global(.dark) .sidebar-link:hover {
    background: rgb(30 58 138 / 0.5);
  }

  /* ── Footer ── */
  .project-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(229 231 235);
  }
  :global(.dark) .project-footer { border-top-color: rgb(55 65 81); }

  .project-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(37 99 235);
    background: rgb(239 246 255);
    border: 1px solid rgb(191 219 254);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .back-btn:hover {
    background: rgb(219 234 254);
    border-color: rgb(147 197 253);
  }
  :global(.dark) .back-btn {
    color: rgb(96 165 250);
    background: rgb(23 37 84 / 0.4);
    border-color: rgb(30 58 138);
  }
  :global(.dark) .back-btn:hover {
    background: rgb(30 58 138 / 0.5);
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(55 65 81);
    background: white;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .share-btn:hover {
    background: rgb(249 250 251);
    border-color: rgb(156 163 175);
  }
  :global(.dark) .share-btn {
    color: rgb(209 213 219);
    background: rgb(31 41 55);
    border-color: rgb(55 65 81);
  }
  :global(.dark) .share-btn:hover {
    background: rgb(55 65 81);
  }

  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // ── Code block: language badge + copy button ──
  document.querySelectorAll('pre').forEach(pre => {
    const code = pre.querySelector('code');
    const lang = pre.getAttribute('data-language') ?? (code?.className ?? '').match(/language-(\w+)/)?.[1];

    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'position:relative';
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    if (lang) {
      const badge = document.createElement('span');
      badge.textContent = lang;
      badge.style.cssText = `
        position:absolute; top:0.6rem; left:0.9rem;
        font-size:0.65rem; font-weight:700; letter-spacing:0.08em;
        text-transform:uppercase; color:rgb(148 163 184);
        pointer-events:none; user-select:none;
      `;
      wrapper.appendChild(badge);
    }

    const copyBtn = document.createElement('button');
    copyBtn.textContent = 'Copy';
    copyBtn.style.cssText = `
      position:absolute; top:0.55rem; right:0.7rem;
      padding:0.2rem 0.6rem; font-size:0.7rem; font-weight:600;
      background:rgb(51 65 85); color:rgb(203 213 225);
      border:1px solid rgb(71 85 105); border-radius:0.375rem;
      cursor:pointer; transition:background 0.15s;
    `;
    copyBtn.onmouseenter = () => copyBtn.style.background = 'rgb(71 85 105)';
    copyBtn.onmouseleave = () => copyBtn.style.background = 'rgb(51 65 85)';
    copyBtn.onclick = async () => {
      await navigator.clipboard.writeText(code?.innerText ?? '');
      copyBtn.textContent = 'Copied!';
      copyBtn.style.color = 'rgb(134 239 172)';
      setTimeout(() => {
        copyBtn.textContent = 'Copy';
        copyBtn.style.color = 'rgb(203 213 225)';
      }, 1800);
    };
    wrapper.appendChild(copyBtn);
  });

  // ── Share / copy-link button ──
  document.getElementById('share-btn')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    const label = document.getElementById('share-label');
    if (label) {
      label.textContent = 'Copied!';
      setTimeout(() => { label.textContent = 'Copy link'; }, 1800);
    }
  });
</script>
